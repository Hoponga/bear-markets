# Arbitrage Bot Configuration

# INFO shows startup and each cycle; WARNING is quiet unless errors (Docker default was WARNING before compose set INFO).
LOG_LEVEL=INFO

# Backend API URL
# For local development: http://localhost:8000
# For Docker: http://backend:8000
API_URL=http://localhost:8000

# Bot credentials (will auto-register if account doesn't exist)
BOT_EMAIL=arbitrage-bot@bearmarket.local
BOT_PASSWORD=ArbitrageBot123!SecurePassword

# Polling interval in seconds
POLL_INTERVAL=10

# Number of shares to buy when seeding a new market
SEED_QUANTITY=50

# After seeding, skip mint/redeem arb this many poll cycles (avoids trading on book state from the seed itself)
SEED_ARB_COOLDOWN_POLLS=2

# When the book has no asks, seeding uses complementary limit BUYs to mint; NO leg uses (1 - this price)
SEED_MINT_YES_PRICE=0.5

# Minting arbitrage threshold
# Buy both YES and NO if best_ask_yes + best_ask_no < this value
MINTING_THRESHOLD=0.99

# Redemption arbitrage threshold
# Sell both YES and NO if best_bid_yes + best_bid_no > this value
REDEMPTION_THRESHOLD=1.01
